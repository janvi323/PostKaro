# ================================
# PostKaro Frontend — Environment
# ================================
# Copy this file to .env and fill in your real values.
# These VITE_ prefixed vars are injected at BUILD TIME — do NOT put secrets here.

# ── Backend API base URL ──────────────────────────────────────────────────────
# The {BASE_URL}/api path where the backend serves endpoints.
# Development (Vite proxy):   /api or leave empty
# Development (direct):       http://localhost:5000/api
# Production (Render):        https://postkaro-main.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ── Socket / static-file base URL ────────────────────────────────────────────
# Used to prefix relative image/avatar paths from the backend.
# Development (Vite proxy):   /socket.io or leave empty
# Development (direct):       http://localhost:5000
# Production (Render):        https://postkaro-main.onrender.com
VITE_SOCKET_URL=http://localhost:5000

# ── App name ───────────────────────────────────────────────────────────────────
VITE_APP_NAME=PostKaro
