# PostKaro Backend - local environment example
# Copy to .env for local development. Never commit real secrets.

NODE_ENV=development
PORT=5000

# MongoDB Atlas. Include the database name after .mongodb.net/.
MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/postkaro?retryWrites=true&w=majority&appName=Cluster0

# Use strong random strings. Production requires at least 32 characters.
SESSION_SECRET=change_me_to_a_random_32_char_session_secret
JWT_SECRET=change_me_to_a_random_32_char_jwt_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=postkaro-api
JWT_AUDIENCE=postkaro-web

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL for CORS and OAuth redirects. Comma-separate if needed.
FRONTEND_URL=http://localhost:5173

# Email password reset. For Gmail, use a Gmail app password.
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Optional media providers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PEXELS_API_KEY=your_pexels_api_key
