# PostKaro Backend - Render production environment variables
# Add these in Render Dashboard > Service > Environment.
# Never commit real production values.

NODE_ENV=production
PORT=5000

# MongoDB Atlas
# Copy from Atlas > Connect > Drivers, then include /postkaro before the query string.
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/postkaro?retryWrites=true&w=majority&appName=Cluster0

# Required strong secrets. Generate locally with: openssl rand -base64 32
SESSION_SECRET=replace_with_at_least_32_random_characters
JWT_SECRET=replace_with_another_32_random_characters
JWT_EXPIRES_IN=7d
JWT_ISSUER=postkaro-api
JWT_AUDIENCE=postkaro-web

# Google OAuth
# Authorized redirect URI in Google Console:
# https://YOUR_RENDER_SERVICE.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://YOUR_RENDER_SERVICE.onrender.com/api/auth/google/callback

# Vercel frontend origin. Comma-separate preview/custom domains if needed.
FRONTEND_URL=https://YOUR_VERCEL_APP.vercel.app

# Email password reset. Gmail requires 2FA + app password.
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Optional providers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PEXELS_API_KEY=your_pexels_api_key
